#!/usr/bin/env python3
"""
pancake — operate on a pancake-os kit (list / history / add / install /
rollback / swap).

A "kit" is a directory laid out per DESIGN.md:
    repo/<pkg>-<ver>/{image.img, image.hash, image.roothash, manifest.toml}
    generations/<n>/{manifest.toml, lowers}
    current → generations/<n>

By default, --kit defaults to /var/lib/pancake/ (the in-system path). For
host-side use point it at the kit directory you built with pancake-bootstrap.

Subcommands:
    list                 packages in the active generation
    history              all generations, parent → child chain
    show <pkg>           manifest of one package
    add <foo.deb>        build a new layer from a .deb, create generation N+1
    install <pkg>...     apt-resolve + build deps as layers, create gen N+1
    activate <id>        flip current → generations/<id> (offline only)
    rollback             current → previous generation
    swap [<id>]          live pivot_root the running rootfs onto gen <id>
                         (or latest); only valid inside a running pancake-os
"""
from __future__ import annotations

import argparse
import datetime as dt
import os
import shutil
import sys
import tempfile
import tomllib
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from pancake_lib import (
    deb_metadata, dpkg_query, file_sha256, installed_packages,
    make_verity_image, package_field, package_files, parse_depends, run,
    slugify_version, stage_files, write_manifest,
)


def kit_path(kit_arg: str | None) -> Path:
    p = Path(kit_arg or "/var/lib/pancake")
    if not p.is_dir():
        sys.exit(f"pancake: kit dir not found: {p}")
    return p


def find_helper(name: str, source_subdir: str | None = None,
                source_basename: str | None = None) -> Path:
    """Locate a helper binary like mount-overlay or pivot-root.

    Search order:
      1. /sbin/<name>           (in-VM install via pancake-state)
      2. /usr/local/sbin/<name>
      3. <source_root>/<source_subdir>/<name> (uncompiled source-tree fallback;
         compiled on demand from <source_basename> if missing)
    """
    for candidate in (Path(f"/sbin/{name}"),
                      Path(f"/usr/local/sbin/{name}")):
        if candidate.is_file() and os.access(candidate, os.X_OK):
            return candidate
    if source_subdir:
        src_root = Path(__file__).resolve().parent.parent
        bin_path = src_root / source_subdir / name
        if bin_path.is_file():
            return bin_path
        if source_basename:
            cc_path = src_root / source_subdir / source_basename
            if cc_path.is_file():
                run(["cc", "-O2", "-o", str(bin_path), str(cc_path)])
                return bin_path
    sys.exit(f"pancake: cannot find helper '{name}' "
             f"(checked /sbin, /usr/local/sbin, source tree)")


def running_in_pancake_os() -> bool:
    """True if we're booted from a pancake-os overlay rootfs."""
    try:
        with open("/proc/mounts") as f:
            for line in f:
                fields = line.split()
                if len(fields) >= 3 and fields[1] == "/" and fields[2] == "overlay":
                    return Path("/lowers").is_dir()
    except OSError:
        pass
    return False


def load_toml(p: Path) -> dict:
    with open(p, "rb") as f:
        return tomllib.load(f)


def current_generation(kit: Path) -> Path:
    """Return the actual generations/<n>/ dir, resolving the 'current' symlink."""
    cur = kit / "current"
    if not cur.exists():
        sys.exit("pancake: no 'current' symlink in kit")
    return cur.resolve()


def latest_generation_id(kit: Path) -> int:
    gens = (kit / "generations")
    if not gens.is_dir():
        return 0
    return max((int(d.name) for d in gens.iterdir() if d.name.isdigit()),
               default=0)


# ───── subcommands ─────────────────────────────────────────────────────────


def cmd_list(kit: Path, _args) -> int:
    gen = current_generation(kit)
    m = load_toml(gen / "manifest.toml")
    print(f"generation {m['generation']['id']}  "
          f"({m['generation']['description']})")
    print(f"  created: {m['generation']['created']}")
    print(f"  layers : {len(m.get('layer', []))}")
    print()
    print(f"  {'name':<36}  {'version':<28}")
    for L in m.get("layer", []):
        print(f"  {L['name']:<36}  {L['version']:<28}")
    return 0


def cmd_history(kit: Path, _args) -> int:
    gens = (kit / "generations")
    cur_id = int(current_generation(kit).name)
    rows = []
    for d in sorted((d for d in gens.iterdir() if d.name.isdigit()),
                    key=lambda d: int(d.name)):
        m = load_toml(d / "manifest.toml")["generation"]
        rows.append(m)
    print(f"  {'id':>4}  {'created':<25}  {'layers':>6}  description")
    for m in rows:
        marker = " *" if m["id"] == cur_id else "  "
        n_layers = len(load_toml(gens / str(m["id"]) / "manifest.toml")
                       .get("layer", []))
        print(f"{marker}{m['id']:>4}  {m['created']:<25}  {n_layers:>6}  "
              f"{m['description']}")
    return 0


def cmd_show(kit: Path, args) -> int:
    gen = current_generation(kit)
    m = load_toml(gen / "manifest.toml")
    found = None
    for L in m.get("layer", []):
        if L["name"] == args.pkg:
            found = L
            break
    if not found:
        sys.exit(f"pancake: {args.pkg} not in current generation")
    pkg_manifest = kit / found["manifest"]
    print(pkg_manifest.read_text())
    return 0


def _new_generation_dir(kit: Path) -> tuple[Path, int]:
    next_id = latest_generation_id(kit) + 1
    new = kit / "generations" / str(next_id)
    new.mkdir(parents=True)
    return new, next_id


def _write_generation(kit: Path, gen_dir: Path, gen_id: int,
                      parent_id: int, description: str,
                      layers: list[dict]) -> None:
    """Write generations/N/{manifest.toml, lowers}."""
    now = dt.datetime.now(dt.timezone.utc).isoformat(timespec="seconds")
    lines = [
        "schema = 1", "",
        "[generation]",
        f"id          = {gen_id}",
        f"parent      = {parent_id}",
        f'created     = "{now}"',
        f'description = "{description}"',
        "",
    ]
    lowers_lines = [
        f"# fs-pancake generation {gen_id} lowers",
        "# slug<TAB>image<TAB>hash<TAB>roothash",
        "# overlay order: leftmost (top) FIRST",
    ]
    for L in layers:
        lines += [
            "[[layer]]",
            f'name     = "{L["name"]}"',
            f'version  = "{L["version"]}"',
            f'manifest = "{L["manifest"]}"',
            "",
        ]
        slug = Path(L["manifest"]).parent.name
        roothash = (kit / "repo" / slug / "image.roothash").read_text().strip()
        lowers_lines.append(
            f"{slug}\trepo/{slug}/image.img\trepo/{slug}/image.hash\t{roothash}"
        )
    (gen_dir / "manifest.toml").write_text("\n".join(lines))
    (gen_dir / "lowers").write_text("\n".join(lowers_lines) + "\n")


def materialize_current(kit: Path, scratch: Path) -> Path:
    """Construct a read-only union of the current generation's layers
    at <scratch>/sandbox. Yields a path suitable as pancake-build --lower.

    Mechanism: veritysetup open each layer + RO mount each + mount-overlay
    them all into one merged view. The caller is responsible for tearing
    these down (via teardown_materialized) before scratch is removed.
    """
    cur_m = load_toml(current_generation(kit) / "manifest.toml")
    layers = cur_m.get("layer", [])
    print(f"[pancake] materializing current generation as overlay "
          f"({len(layers)} layers, no sandbox copy needed)", file=sys.stderr)

    scratch.mkdir(parents=True, exist_ok=True)
    lowers_dir = scratch / "lowers"
    sandbox = scratch / "sandbox"
    rw_root = scratch / "rw"
    for d in (lowers_dir, sandbox, rw_root):
        d.mkdir(parents=True, exist_ok=True)

    # overlayfs rejects upperdir/workdir that are themselves on overlayfs
    # (which is the case inside pancake-os, where / is the runtime overlay).
    # Mount a fresh tmpfs over rw_root so upper/work always live on a plain
    # filesystem regardless of where scratch sits.
    run(["mount", "-t", "tmpfs", "-o", "mode=755", "tmpfs", str(rw_root)],
        sudo=True)
    upper = rw_root / "upper"
    work = rw_root / "work"
    upper.mkdir(parents=True, exist_ok=True)
    work.mkdir(parents=True, exist_ok=True)

    opened: list[str] = []
    mounted: list[Path] = [rw_root]   # tmpfs needs unmounting in teardown
    state_path = scratch / "state"
    state_path.write_text("")

    # Per-add tag so device-mapper names can't collide across runs.
    tag = f"pkadd{os.getpid()}"

    try:
        lower_args: list[str] = []
        for L in layers:
            slug = Path(L["manifest"]).parent.name
            img = kit / "repo" / slug / "image.img"
            hashf = kit / "repo" / slug / "image.hash"
            rh = (kit / "repo" / slug / "image.roothash").read_text().strip()
            dm_name = f"v_{tag}_{slug}"[:120]   # kernel limit safety
            run(["veritysetup", "open", str(img), dm_name, str(hashf), rh],
                sudo=True)
            opened.append(dm_name)
            mp = lowers_dir / slug
            mp.mkdir(exist_ok=True)
            run(["mount", "-o", "ro", f"/dev/mapper/{dm_name}", str(mp)],
                sudo=True)
            mounted.append(mp)
            lower_args += ["--lower", str(mp)]

        # Use the same mount-overlay binary the initramfs uses (handles
        # 100+ lowers via fsconfig instead of hitting mount(2)'s 4KiB cap).
        mount_overlay = find_helper("mount-overlay", "initramfs",
                                    "mount-overlay.c")
        run([str(mount_overlay), "--upper", str(upper), "--work", str(work),
             "--target", str(sandbox)] + lower_args, sudo=True)
        mounted.append(sandbox)

        # Record what was opened/mounted so teardown can clean up.
        state_path.write_text(
            "\n".join(["OPENED:" + n for n in opened] +
                      ["MOUNTED:" + str(p) for p in mounted]) + "\n")
        return sandbox
    except Exception:
        # Best-effort teardown if setup fails partway.
        for p in reversed(mounted):
            run(["umount", "-l", str(p)], sudo=True, check=False)
        for n in reversed(opened):
            run(["veritysetup", "close", n], sudo=True, check=False)
        raise


def teardown_materialized(scratch: Path) -> None:
    """Reverse of materialize_current()."""
    state_path = scratch / "state"
    if not state_path.is_file():
        return
    lines = state_path.read_text().strip().splitlines()
    mounted = [l[8:] for l in lines if l.startswith("MOUNTED:")]
    opened = [l[7:] for l in lines if l.startswith("OPENED:")]
    for p in reversed(mounted):
        run(["umount", "-l", p], sudo=True, check=False)
    for n in reversed(opened):
        run(["veritysetup", "close", n], sudo=True, check=False)


def cmd_add(kit: Path, args) -> int:
    """Build a new pancake layer from a .deb and create generation N+1."""
    deb = Path(args.deb)
    if not deb.is_file():
        sys.exit(f"pancake: no such .deb: {deb}")

    print(f"[pancake] building layer from {deb.name}", file=sys.stderr)
    md = deb_metadata(deb)
    name, version = md["Package"], md["Version"]
    slug = f"{name}-{slugify_version(version)}"
    pkg_dir = kit / "repo" / slug
    if pkg_dir.exists():
        sys.exit(f"pancake: layer {slug} already exists in repo")

    cur_m = load_toml(current_generation(kit) / "manifest.toml")

    # Sandbox source: prefer kept _sandbox if present (faster — no overlay
    # setup), else materialize via veritysetup + mount-overlay.
    kept = kit / "_sandbox"
    if kept.is_dir():
        sandbox = kept
        scratch = None
    else:
        scratch = Path(tempfile.mkdtemp(prefix="pancake-add-"))
        try:
            sandbox = materialize_current(kit, scratch)
        except Exception:
            shutil.rmtree(scratch, ignore_errors=True)
            raise

    try:
        bld = Path(__file__).resolve().parent / "pancake-build"
        run([str(bld), "--deb", str(deb), "--lower", str(sandbox),
             "--repo", str(kit / "repo")], sudo=True)
    finally:
        if scratch:
            teardown_materialized(scratch)
            shutil.rmtree(scratch, ignore_errors=True)

    # Build the new generation manifest = current + new layer (at the top).
    new_layer = {
        "name": name,
        "version": version,
        "manifest": f"repo/{slug}/manifest.toml",
    }
    new_layers = [new_layer] + list(cur_m.get("layer", []))

    cur_id = int(current_generation(kit).name)
    gen_dir, new_id = _new_generation_dir(kit)
    _write_generation(
        kit, gen_dir, new_id, parent_id=cur_id,
        description=f"+{name} {version}",
        layers=new_layers,
    )

    if args.activate:
        cur = kit / "current"
        if cur.exists() or cur.is_symlink():
            cur.unlink()
        cur.symlink_to(f"generations/{new_id}")
        print(f"[pancake] activated generation {new_id}", file=sys.stderr)
    else:
        print(f"[pancake] generation {new_id} staged. "
              f"`pancake activate {new_id}` to switch.", file=sys.stderr)
    return 0


def _bind_chroot_runtime(sandbox: Path) -> list[Path]:
    """Bind /proc, /sys, /dev into a chroot and copy /etc/resolv.conf.
    Returns the list of bind targets so the caller can umount them."""
    bound: list[Path] = []
    for sub in ("proc", "sys", "dev"):
        tgt = sandbox / sub
        run(["mkdir", "-p", str(tgt)], sudo=True)
        run(["mount", "--rbind", f"/{sub}", str(tgt)], sudo=True)
        run(["mount", "--make-rslave", str(tgt)], sudo=True, check=False)
        bound.append(tgt)
    # /tmp: apt drops privs to _apt user which needs a sticky world-writable
    # /tmp to stage apt-key configs. No .deb ships /tmp so we create it.
    run(["install", "-d", "-m", "1777", str(sandbox / "tmp")], sudo=True)
    # apt empty-dir scaffolding. New layers built by `pancake install` will
    # carry these via the package_files fix; older layers in the kit were
    # built before that fix, so create the dirs here as a fallback.
    for d in ("var/cache/apt/archives/partial",
              "var/lib/apt/lists/partial",
              "var/log/apt",
              "var/log",
              "etc/apt/preferences.d",
              "etc/apt/sources.list.d",
              "etc/apt/apt.conf.d",
              "etc/apt/auth.conf.d",
              "etc/apt/keyrings"):
        run(["install", "-d", "-m", "0755", str(sandbox / d)], sudo=True)
    # DNS: copy host resolv.conf so apt-get can resolve archive mirrors.
    host_resolv = Path("/etc/resolv.conf")
    if host_resolv.exists():
        run(["mkdir", "-p", str(sandbox / "etc")], sudo=True)
        run(["cp", "-f", "--dereference", str(host_resolv),
             str(sandbox / "etc/resolv.conf")], sudo=True)
    return bound


def _unbind_chroot_runtime(bound: list[Path]) -> None:
    for p in reversed(bound):
        run(["umount", "-l", str(p)], sudo=True, check=False)


def cmd_install(kit: Path, args) -> int:
    """Install one or more package names: apt-get download into a materialized
    chroot, snapshot each newly-installed package as a pancake layer, write
    generation N+1.

    The .deb resolution + dependency closure is delegated to apt inside the
    sandbox — same source of truth as the bootstrap kit's repo configuration.
    """
    cur_m = load_toml(current_generation(kit) / "manifest.toml")
    cur_pkgs = {L["name"] for L in cur_m.get("layer", [])}

    scratch = Path(tempfile.mkdtemp(prefix="pancake-install-"))
    bound: list[Path] = []
    try:
        sandbox = materialize_current(kit, scratch)
        bound = _bind_chroot_runtime(sandbox)

        env = {**os.environ,
               "DEBIAN_FRONTEND": "noninteractive",
               "DPKG_FORCE": "confnew",
               "PATH": "/usr/sbin:/usr/bin:/sbin:/bin",
               "LANG": "C.UTF-8"}
        print(f"[pancake] apt update + install {args.packages}", file=sys.stderr)
        run(["chroot", str(sandbox), "apt-get", "update", "-q", "-y"],
            sudo=True, env=env)
        run(["chroot", str(sandbox), "apt-get", "install", "-y",
             "--no-install-recommends",
             "-o", "Dpkg::Options::=--force-confnew",
             *args.packages],
            sudo=True, env=env)

        # Diff against current generation to find newly-installed packages.
        all_now = installed_packages(sandbox)
        new_pkgs = [(n, v, a) for (n, v, a) in all_now
                    if n not in cur_pkgs and n != "pancake-state"]
        print(f"[pancake] {len(new_pkgs)} new packages "
              f"(after dep resolution)", file=sys.stderr)
        if not new_pkgs:
            print("[pancake] nothing to do — already installed in current "
                  "generation", file=sys.stderr)
            return 0

        new_layers: list[dict] = []
        with tempfile.TemporaryDirectory(prefix="pancake-install-stage-") as st:
            stage_root = Path(st)
            for name, version, arch in new_pkgs:
                print(f"  → {name} {version}", file=sys.stderr)
                files = package_files(sandbox, name)
                staging = stage_root / name
                stage_files(sandbox, files, staging)

                slug = f"{name}-{slugify_version(version)}"
                pkg_dir = kit / "repo" / slug
                if pkg_dir.exists():
                    run(["rm", "-rf", str(pkg_dir)], sudo=True)
                pkg_dir.mkdir(parents=True)

                roothash, data_size = make_verity_image(
                    staging, pkg_dir / "image.img", label=f"pk-{name[:12]}")
                description = package_field(sandbox, name, "Description")\
                    .splitlines()[0].replace('"', "'")
                depends = parse_depends(package_field(sandbox, name, "Depends"))
                write_manifest(
                    pkg_dir,
                    name=name, version=version, arch=arch,
                    description=description, depends=depends,
                    roothash=roothash, data_size=data_size,
                )
                new_layers.append({
                    "name": name, "version": version,
                    "manifest": f"repo/{slug}/manifest.toml",
                })

        # New generation = new layers (top) + everything currently active.
        cur_id = int(current_generation(kit).name)
        gen_dir, new_id = _new_generation_dir(kit)
        all_layers = new_layers + list(cur_m.get("layer", []))
        _write_generation(
            kit, gen_dir, new_id, parent_id=cur_id,
            description=f"install {','.join(args.packages)} "
                        f"({len(new_pkgs)} new layers)",
            layers=all_layers,
        )

        if args.activate:
            cur = kit / "current"
            if cur.exists() or cur.is_symlink():
                cur.unlink()
            cur.symlink_to(f"generations/{new_id}")
            print(f"[pancake] activated generation {new_id}", file=sys.stderr)
        else:
            print(f"[pancake] generation {new_id} staged. "
                  f"`pancake activate {new_id}` to switch.", file=sys.stderr)

    finally:
        _unbind_chroot_runtime(bound)
        teardown_materialized(scratch)
        shutil.rmtree(scratch, ignore_errors=True)

    return 0


def cmd_activate(kit: Path, args) -> int:
    target = kit / "generations" / str(args.id)
    if not target.is_dir():
        sys.exit(f"pancake: no such generation: {args.id}")
    cur = kit / "current"
    if cur.exists() or cur.is_symlink():
        cur.unlink()
    cur.symlink_to(f"generations/{args.id}")
    print(f"[pancake] current → generations/{args.id}", file=sys.stderr)
    return 0


def _parse_lowers_file(path: Path) -> list[dict]:
    """Parse generations/N/lowers (slug<TAB>image<TAB>hash<TAB>roothash)."""
    layers: list[dict] = []
    for line in path.read_text().splitlines():
        if not line or line.startswith("#"):
            continue
        parts = line.split("\t")
        if len(parts) != 4:
            continue
        layers.append({"slug": parts[0], "image": parts[1],
                       "hash": parts[2], "roothash": parts[3]})
    return layers


def _is_mounted(path: Path) -> bool:
    try:
        with open("/proc/mounts") as f:
            for line in f:
                parts = line.split()
                if len(parts) >= 2 and parts[1] == str(path):
                    return True
    except OSError:
        pass
    return False


def cmd_swap(kit: Path, args) -> int:
    """Live pivot_root swap to a target generation.

    Mechanism:
      1. veritysetup-open + RO-mount any layers in target gen not already
         mounted under /lowers.
      2. Build a fresh overlay at /pancake-newroot using mount-overlay.
      3. rbind /proc /sys /dev /run /lowers and bind /var/lib/pancake into
         the new root so the running system retains its kernel/runtime state
         across the swap.
      4. Atomically flip kit/current → generations/<id>.
      5. Make / and /pancake-newroot rprivate (pivot_root requires it).
      6. Invoke the pivot-root helper which does
            chdir(newroot); pivot_root(".", "./oldroot"); umount2 oldroot.
      7. Re-mark / as shared (systemd's expected default).
      8. veritysetup-close any layers no longer used.
    """
    if not running_in_pancake_os():
        sys.exit("pancake swap: must be run from inside a booted pancake-os "
                 "(no overlay rootfs detected)")

    target_id = args.id if args.id else latest_generation_id(kit)
    target_gen = kit / "generations" / str(target_id)
    if not target_gen.is_dir():
        sys.exit(f"pancake swap: no such generation: {target_id}")
    if not (target_gen / "lowers").is_file():
        sys.exit(f"pancake swap: {target_gen}/lowers missing")

    cur_id = int(current_generation(kit).name)
    if cur_id == target_id:
        print(f"[swap] already on generation {target_id}", file=sys.stderr)
        return 0

    target_layers = _parse_lowers_file(target_gen / "lowers")
    cur_layers = _parse_lowers_file(current_generation(kit) / "lowers")
    cur_slugs = {l["slug"] for l in cur_layers}
    target_slugs = {l["slug"] for l in target_layers}

    # 1. Open + RO-mount layers we don't already have under /lowers.
    print(f"[swap] preparing {len(target_layers)} layers "
          f"({len(target_slugs - cur_slugs)} new, "
          f"{len(cur_slugs - target_slugs)} to retire)", file=sys.stderr)
    for L in target_layers:
        if L["slug"] in cur_slugs:
            continue
        img = kit / L["image"]
        hashf = kit / L["hash"]
        run(["veritysetup", "open", str(img), f"v_{L['slug']}",
             str(hashf), L["roothash"]], sudo=True)
        mp = Path(f"/lowers/{L['slug']}")
        mp.mkdir(parents=True, exist_ok=True)
        run(["mount", "-o", "ro", f"/dev/mapper/v_{L['slug']}", str(mp)],
            sudo=True)

    # 2. Build the new overlay at /pancake-newroot, with its own tmpfs upper.
    newroot = Path("/pancake-newroot")
    newroot.mkdir(exist_ok=True)
    new_rw = Path("/run/pancake-newrw")
    if not _is_mounted(new_rw):
        new_rw.mkdir(parents=True, exist_ok=True)
        run(["mount", "-t", "tmpfs", "-o", "mode=755", "tmpfs", str(new_rw)],
            sudo=True)
    upper = new_rw / "upper"
    work = new_rw / "work"
    upper.mkdir(exist_ok=True)
    work.mkdir(exist_ok=True)

    mount_overlay = find_helper("mount-overlay", "initramfs", "mount-overlay.c")
    lower_args: list[str] = []
    for L in target_layers:
        lower_args += ["--lower", f"/lowers/{L['slug']}"]
    run([str(mount_overlay), "--upper", str(upper), "--work", str(work),
         "--target", str(newroot)] + lower_args, sudo=True)

    # 3. Bring kernel/runtime mounts into the new root. Use rbind for trees
    # that already contain submounts; bind for single-mount paths.
    for sub in ("proc", "sys", "dev", "run"):
        (newroot / sub).mkdir(exist_ok=True)
        run(["mount", "--rbind", f"/{sub}", str(newroot / sub)], sudo=True)
    (newroot / "var/lib/pancake").mkdir(parents=True, exist_ok=True)
    run(["mount", "--bind", "/var/lib/pancake",
         str(newroot / "var/lib/pancake")], sudo=True)
    (newroot / "lowers").mkdir(exist_ok=True)
    run(["mount", "--rbind", "/lowers", str(newroot / "lowers")], sudo=True)

    # 4. Flip current → target ATOMICALLY (rename of a sibling symlink, so
    # if pivot fails the symlink is consistent for next boot).
    cur_link = kit / "current"
    tmp_link = kit / "current.swap.tmp"
    if tmp_link.exists() or tmp_link.is_symlink():
        tmp_link.unlink()
    tmp_link.symlink_to(f"generations/{target_id}")
    os.rename(str(tmp_link), str(cur_link))
    print(f"[swap] current → generations/{target_id} (committed)",
          file=sys.stderr)

    # 5. pivot_root prerequisites: neither old nor new root may be MS_SHARED.
    # systemd marks / as shared at boot; clear that recursively.
    run(["mount", "--make-rprivate", "/"], sudo=True)
    run(["mount", "--make-rprivate", str(newroot)], sudo=True)

    # 6. The pivot itself. chdir(/) so our cwd doesn't anchor old root mounts.
    os.chdir("/")
    pivot_root_bin = find_helper("pivot-root", ".", "pivot-root.c")
    run([str(pivot_root_bin), str(newroot)], sudo=True)

    # 7. Restore / as shared so systemd's mount-propagation expectations hold.
    run(["mount", "--make-rshared", "/"], sudo=True, check=False)

    # 8. Close layers no longer referenced (best-effort; udev triggers can
    # delay device close).
    retired = cur_slugs - target_slugs
    for slug in retired:
        run(["umount", "-l", f"/lowers/{slug}"], sudo=True, check=False)
        run(["veritysetup", "close", f"v_{slug}"], sudo=True, check=False)

    print(f"[swap] live swap complete — running generation {target_id}",
          file=sys.stderr)
    return 0


def cmd_rollback(kit: Path, _args) -> int:
    cur_id = int(current_generation(kit).name)
    cur_m = load_toml(current_generation(kit) / "manifest.toml")
    parent = cur_m["generation"]["parent"]
    if not parent:
        sys.exit("pancake: current generation has no parent")
    return cmd_activate(kit, argparse.Namespace(id=parent))


# ───── argparse plumbing ───────────────────────────────────────────────────


def main() -> int:
    ap = argparse.ArgumentParser(prog="pancake", description=__doc__,
                                 formatter_class=argparse.RawDescriptionHelpFormatter)
    ap.add_argument("--kit", default="/var/lib/pancake",
                    help="kit directory (default: /var/lib/pancake)")
    sub = ap.add_subparsers(dest="cmd", required=True)

    sub.add_parser("list", help="show packages in the active generation")
    sub.add_parser("history", help="list all generations")

    sp = sub.add_parser("show", help="dump a package's manifest")
    sp.add_argument("pkg")

    sp = sub.add_parser("add",
                        help="build a new layer from a .deb + create gen N+1")
    sp.add_argument("deb")
    sp.add_argument("--activate", action="store_true",
                    help="immediately set current → the new generation")

    sp = sub.add_parser(
        "install",
        help="install packages by name (apt resolves deps) + create gen N+1",
    )
    sp.add_argument("packages", nargs="+",
                    help="package names (apt-get inside the chroot resolves)")
    sp.add_argument("--activate", action="store_true",
                    help="immediately set current → the new generation")

    sp = sub.add_parser("activate", help="set current → generations/<id>")
    sp.add_argument("id", type=int)

    sub.add_parser("rollback", help="current → previous generation")

    sp = sub.add_parser(
        "swap",
        help="live pivot_root onto a generation (in-VM only); no reboot",
    )
    sp.add_argument("id", type=int, nargs="?",
                    help="target generation id (default: latest)")

    args = ap.parse_args()
    kit = kit_path(args.kit)

    fn = {
        "list": cmd_list, "history": cmd_history, "show": cmd_show,
        "add": cmd_add, "install": cmd_install,
        "activate": cmd_activate, "rollback": cmd_rollback,
        "swap": cmd_swap,
    }[args.cmd]
    return fn(kit, args)


if __name__ == "__main__":
    sys.exit(main())
