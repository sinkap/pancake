#!/usr/bin/env python3
"""
pancake-bootstrap — build a complete pancake-os kit from a Debian package list.

Process:

  1. Run mmdebstrap to create a sandbox/ with all packages installed.
     (postinsts run, /etc/passwd populated, systemd units enabled, etc.)
  2. For each installed package P:
       files = dpkg-query --admindir=sandbox/var/lib/dpkg -L P
       copy those files into a per-package staging dir
       build a verity image + manifest for P
  3. Compute orphan files (in sandbox/ but not owned by any package):
       these include /etc/passwd entries postinsts added,
       multi-user.target.wants symlinks, etc.
       package them as a special "pancake-state" layer.
  4. Topological-sort the layers by Depends and write generations/1/manifest.toml
     listing them in overlay order (leaves first → base last; leftmost wins).

Usage:
  pancake-bootstrap --suite noble --packages openssh-server,chrony \\
                    --output /tmp/kit
"""
from __future__ import annotations

import argparse
import os
import re
import shutil
import sys
import tempfile
from collections import defaultdict
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from pancake_lib import (
    canonical_in_sandbox, dpkg_query, installed_packages, make_verity_image,
    package_field, package_files, parse_depends, run, slugify_version,
    stage_files, write_manifest,
)


# Packages every pancake-os install needs that minbase does NOT pull.
# init pulls systemd-sysv → systemd → libpam-systemd, etc.
SYSTEM_BASELINE = [
    "init", "systemd", "systemd-sysv", "libpam-systemd",
    "udev",                         # device-node management
    "dbus",                         # systemctl talks via D-Bus
    "iproute2", "iputils-ping",     # basic networking
    "ca-certificates", "netbase",
    "kmod",                         # modprobe
    "cryptsetup-bin", "dmsetup",    # verity tools + udev rules
    "openssh-client",               # ssh into the VM uses host's client; nice to have
    "less", "procps",
    # apt is required by `pancake install <name>` (resolves deps + downloads
    # .debs via the materialized chroot). Without it we can only `pancake add
    # <foo.deb>`.
    "apt",
    # python3 runs the in-VM `pancake` CLI itself.
    "python3",
]


def mmdebstrap_sandbox(suite: str, mirror: str, packages: list[str],
                       sandbox: Path) -> None:
    if sandbox.exists():
        run(["rm", "-rf", str(sandbox)], sudo=True)
    sandbox.parent.mkdir(parents=True, exist_ok=True)
    pkg_csv = ",".join(packages)
    run(["mmdebstrap", "--variant=minbase", "--components=main,universe",
         f"--include={pkg_csv}", suite, str(sandbox), mirror], sudo=True)


# dpkg_query, installed_packages, package_field, package_files,
# canonical_in_sandbox, stage_files now live in pancake_lib (shared with
# pancake-install).


def all_real_files(sandbox: Path) -> set[str]:
    """Every regular file + symlink under sandbox, as paths relative to /."""
    out = run(
        ["find", str(sandbox), "(", "-type", "f", "-o", "-type", "l", ")",
         "-printf", "/%P\\n"],
        capture=True, sudo=True,
    ).stdout
    return set(out.strip().splitlines())


def topological_order(pkgs: list[tuple[str, str, str]],
                      sandbox: Path) -> list[str]:
    """Return package names in DEPENDENCY-FIRST order (libc6 → ... → openssh-server).
    Caller will REVERSE this for overlay order (leaf first)."""
    name_set = {p[0] for p in pkgs}
    # Build edges: dep_name -> {dependent_name}
    # We want dependencies BEFORE dependents.
    deps = defaultdict(set)
    rdeps = defaultdict(set)
    for name, _, _ in pkgs:
        depends = package_field(sandbox, name, "Depends")
        for d in parse_depends(depends):
            # Strip version constraints and alternatives ("a (>= 1) | b").
            for alt in d.split("|"):
                bare = alt.strip().split()[0].split(":")[0]
                if bare in name_set and bare != name:
                    deps[name].add(bare)
                    rdeps[bare].add(name)
                    break  # take first satisfiable alt
    # Kahn topo sort: start with nodes that depend on nothing.
    ready = sorted(n for n, _, _ in pkgs if not deps[n])
    out: list[str] = []
    while ready:
        n = ready.pop(0)
        out.append(n)
        for child in sorted(rdeps[n]):
            deps[child].discard(n)
            if not deps[child]:
                ready.append(child)
                # keep `ready` sorted-ish for determinism
                ready.sort()
    # Anything unresolved → cycle; append in arbitrary order (rare).
    for n, _, _ in pkgs:
        if n not in out:
            out.append(n)
    return out


def write_generation_manifest(gen_dir: Path, layers: list[dict],
                              parent_id: int | None,
                              description: str,
                              repo_dir: Path) -> None:
    """Write the generation manifest (TOML, for tools) plus a sister 'lowers'
    file (TSV, shell-parseable for the initramfs)."""
    import datetime as dt
    now = dt.datetime.now(dt.timezone.utc).isoformat(timespec="seconds")
    gen_id = int(gen_dir.name)
    lines = [
        "schema = 1",
        "",
        "[generation]",
        f"id          = {gen_id}",
        f"parent      = {parent_id if parent_id is not None else 0}",
        f'created     = "{now}"',
        f'description = "{description}"',
        "",
    ]
    for L in layers:
        lines += [
            "[[layer]]",
            f'name     = "{L["name"]}"',
            f'version  = "{L["version"]}"',
            f'manifest = "repo/{L["dir"]}/manifest.toml"',
            "",
        ]
    (gen_dir / "manifest.toml").write_text("\n".join(lines))

    # Sidecar for the initramfs (no TOML parser available there).
    # Format (tab-separated, # lines are comments):
    #   slug \t image_rel \t hash_rel \t roothash
    lowers_lines = [
        "# fs-pancake generation %d lowers" % gen_id,
        "# slug<TAB>image<TAB>hash<TAB>roothash",
        "# overlay order: leftmost (top of stack) FIRST",
    ]
    for L in layers:
        roothash = (repo_dir / L["dir"] / "image.roothash"
                    ).read_text().strip()
        slug = L["dir"]
        lowers_lines.append(
            f"{slug}\trepo/{slug}/image.img\trepo/{slug}/image.hash\t{roothash}"
        )
    (gen_dir / "lowers").write_text("\n".join(lowers_lines) + "\n")


def bake_pancake_runtime(sandbox: Path) -> None:
    """Install the pancake CLI + helpers + a systemd unit so `pancake install`
    and `pancake swap` work inside the booted VM (not just on the host).

    Drops:
      /sbin/mount-overlay     (C, statically linked)
      /sbin/pivot-root        (C, statically linked)
      /usr/local/bin/pancake          (Python)
      /usr/local/bin/pancake_lib.py   (sibling, found via __file__)
      /usr/local/bin/pancake-build    (used by `pancake add`)
      /etc/systemd/system/pancake-state-rw.service  (remounts state rw)
    """
    src_root = Path(__file__).resolve().parent.parent
    print(f"\n[bootstrap] baking pancake runtime into sandbox", file=sys.stderr)

    # 1. Compile statically so binaries don't depend on the guest's glibc
    # version — they invoke syscalls directly + a couple of libc helpers.
    cc_out_dir = sandbox / "sbin"
    run(["mkdir", "-p", str(cc_out_dir)], sudo=True)
    for src_rel, out_name in (
        ("initramfs/mount-overlay.c", "mount-overlay"),
        ("pivot-root.c",              "pivot-root"),
    ):
        src = src_root / src_rel
        if not src.is_file():
            sys.exit(f"[bootstrap] missing source: {src}")
        # Build into /tmp first (host-owned), then sudo install into sandbox.
        tmp_bin = Path(f"/tmp/_pancake-build-{out_name}")
        run(["cc", "-O2", "-static", "-o", str(tmp_bin), str(src)])
        run(["install", "-m", "0755", str(tmp_bin),
             str(cc_out_dir / out_name)], sudo=True)
        tmp_bin.unlink(missing_ok=True)

    # 2. Drop the Python CLI + lib + build helper next to each other so
    # `Path(__file__).resolve().parent` resolves to where pancake_lib.py is.
    bin_dst = sandbox / "usr/local/bin"
    run(["mkdir", "-p", str(bin_dst)], sudo=True)
    for fname in ("pancake", "pancake_lib.py", "pancake-build"):
        src = src_root / "tools" / fname
        if not src.is_file():
            sys.exit(f"[bootstrap] missing tool: {src}")
        run(["install", "-m", "0755" if fname != "pancake_lib.py" else "0644",
             str(src), str(bin_dst / fname)], sudo=True)

    # 3. systemd unit: the initramfs mounts the state partition RO; pancake
    # install/swap need to write into kit/ so we remount rw early.
    unit = sandbox / "etc/systemd/system/pancake-state-rw.service"
    run(["sh", "-c", f"cat > {unit} << 'EOF'\n"
         "[Unit]\n"
         "Description=Remount /var/lib/pancake read-write for pancake CLI\n"
         "DefaultDependencies=no\n"
         "ConditionPathIsMountPoint=/var/lib/pancake\n"
         "After=local-fs.target\n"
         "Before=multi-user.target\n"
         "[Service]\n"
         "Type=oneshot\n"
         "RemainAfterExit=yes\n"
         "ExecStart=/bin/mount -o remount,rw /var/lib/pancake\n"
         "[Install]\n"
         "WantedBy=multi-user.target\n"
         "EOF"], sudo=True)
    run(["mkdir", "-p",
         str(sandbox / "etc/systemd/system/multi-user.target.wants")],
        sudo=True)
    run(["ln", "-sf", "/etc/systemd/system/pancake-state-rw.service",
         str(sandbox / "etc/systemd/system/multi-user.target.wants/"
                       "pancake-state-rw.service")],
        sudo=True)


def customize_sandbox(sandbox: Path, *, hostname: str,
                      ssh_host_keys_dir: Path | None,
                      ssh_authorized_keys: Path | None) -> None:
    """Apply machine-identity customizations after mmdebstrap finishes but
    BEFORE per-package snapshot, so the modified content lands in whichever
    package owns each path (or the orphan pancake-state image)."""
    print(f"\n[bootstrap] customizing sandbox", file=sys.stderr)

    # /etc/hostname — owned by base-files (its content goes into base-files'
    # pancake image).
    print(f"  hostname → {hostname}", file=sys.stderr)
    run(["sh", "-c", f"echo '{hostname}' > {sandbox}/etc/hostname"], sudo=True)

    # SSH host keys — needed for sshd to start. Bake into the kit so a fresh
    # boot has them. Generate fresh if no source dir is given.
    ssh_dir = sandbox / "etc/ssh"
    run(["mkdir", "-p", str(ssh_dir)], sudo=True)
    if ssh_host_keys_dir:
        print(f"  ssh host keys ← {ssh_host_keys_dir}", file=sys.stderr)
        run(["sh", "-c",
             f"cp -a {ssh_host_keys_dir}/ssh_host_* {ssh_dir}/"], sudo=True)
    else:
        print(f"  generating fresh ssh host keys in {ssh_dir}", file=sys.stderr)
        for ktype in ("rsa", "ecdsa", "ed25519"):
            kf = f"{ssh_dir}/ssh_host_{ktype}_key"
            run(["sh", "-c",
                 f"rm -f {kf} {kf}.pub && "
                 f"ssh-keygen -q -N '' -t {ktype} -f {kf}"], sudo=True)
    run(["sh", "-c",
         f"chmod 600 {ssh_dir}/ssh_host_*_key && "
         f"chmod 644 {ssh_dir}/ssh_host_*_key.pub"], sudo=True)

    # authorized_keys for root — only path to log in, since RO rootfs means
    # password auth is awkward (passwd file is in a verity image).
    if ssh_authorized_keys:
        if not ssh_authorized_keys.is_file():
            sys.exit(f"--ssh-authorized-keys: not a file: {ssh_authorized_keys}")
        print(f"  /root/.ssh/authorized_keys ← {ssh_authorized_keys}",
              file=sys.stderr)
        run(["mkdir", "-p", f"{sandbox}/root/.ssh"], sudo=True)
        run(["chmod", "700", f"{sandbox}/root/.ssh"], sudo=True)
        run(["sh", "-c",
             f"cp {ssh_authorized_keys} {sandbox}/root/.ssh/authorized_keys"],
            sudo=True)
        run(["chmod", "600", f"{sandbox}/root/.ssh/authorized_keys"], sudo=True)

    # End-of-boot diagnostic dump → console. Without this we have no way
    # into the booted system (no console getty until late, sshd may not be up).
    debug_unit = sandbox / "etc/systemd/system/pancake-debug.service"
    run(["sh", "-c", f"cat > {debug_unit} << 'EOF'\n"
         "[Unit]\n"
         "Description=pancake-os end-of-boot diagnostic dump\n"
         "DefaultDependencies=no\n"
         "After=multi-user.target\n"
         "[Service]\n"
         "Type=oneshot\n"
         "StandardOutput=journal+console\n"
         "ExecStart=/bin/sh -c 'echo === PANCAKE DEBUG ===; "
                  "echo --- ip ---; ip -4 addr 2>&1 | head -10; "
                  "echo --- ss listening ---; ss -tlnp 2>&1 | head; "
                  "echo --- ssh status ---; systemctl status ssh.socket ssh.service "
                  "--no-pager -l 2>&1 | head -20; "
                  "echo --- /etc/passwd sshd ---; grep ^sshd /etc/passwd; "
                  "echo === END DEBUG ==='\n"
         "[Install]\n"
         "WantedBy=multi-user.target\n"
         "EOF"], sudo=True)
    run(["mkdir", "-p", str(sandbox / "etc/systemd/system/multi-user.target.wants")],
        sudo=True)
    run(["ln", "-sf", "/etc/systemd/system/pancake-debug.service",
         str(sandbox / "etc/systemd/system/multi-user.target.wants/pancake-debug.service")],
        sudo=True)

    # Network: enable DHCP on the first ether iface via systemd-networkd.
    run(["mkdir", "-p", str(sandbox / "etc/systemd/network")], sudo=True)
    run(["sh", "-c", f"cat > {sandbox}/etc/systemd/network/10-wired.network << 'EOF'\n"
         "[Match]\n"
         "Type=ether\n"
         "[Network]\n"
         "DHCP=yes\n"
         "EOF"], sudo=True)
    run(["chroot", str(sandbox), "systemctl", "enable", "systemd-networkd"],
        sudo=True, check=False)
    # qemu user-mode networking provides DNS at 10.0.2.3
    run(["sh", "-c",
         f"echo 'nameserver 10.0.2.3' > {sandbox}/etc/resolv.conf"], sudo=True)

    # Replace /etc/ssh/sshd_config wholesale. The .deb-shipped sshd_config
    # is a stub waiting for debconf to fill it in; sshd_config.d/*.conf is
    # NOT included unless we write the include line ourselves.
    sshd_main = sandbox / "etc/ssh/sshd_config"
    run(["sh", "-c", f"cat > {sshd_main} << 'EOF'\n"
         "# /etc/ssh/sshd_config — pancake-os baseline\n"
         "Port 22\n"
         "HostKey /etc/ssh/ssh_host_rsa_key\n"
         "HostKey /etc/ssh/ssh_host_ecdsa_key\n"
         "HostKey /etc/ssh/ssh_host_ed25519_key\n"
         "PermitRootLogin prohibit-password\n"
         "PasswordAuthentication no\n"
         "PubkeyAuthentication yes\n"
         "AuthorizedKeysFile .ssh/authorized_keys\n"
         "ChallengeResponseAuthentication no\n"
         "UsePAM no\n"
         "UseDNS no\n"
         "GSSAPIAuthentication no\n"
         "X11Forwarding no\n"
         "PrintMotd no\n"
         "AcceptEnv LANG LC_*\n"
         "Subsystem sftp /usr/lib/openssh/sftp-server\n"
         "EOF"], sudo=True)

    # Final step: bake the pancake runtime (CLI, helpers, remount unit) so
    # `pancake install` / `pancake swap` work inside the booted VM.
    bake_pancake_runtime(sandbox)


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("--suite", default="noble")
    ap.add_argument("--mirror", default="http://archive.ubuntu.com/ubuntu/")
    ap.add_argument("--packages", required=True,
                    help="comma-separated extra packages on top of minbase")
    ap.add_argument("--output", required=True, type=Path)
    ap.add_argument("--keep-sandbox", action="store_true",
                    help="don't delete sandbox/ after building")
    ap.add_argument("--hostname", default="pancake",
                    help="hostname baked into /etc/hostname (default: pancake)")
    ap.add_argument("--ssh-host-keys", type=Path, default=None,
                    help="dir with ssh_host_*_key files to use; "
                         "fresh keys are generated if omitted")
    ap.add_argument("--ssh-authorized-keys", type=Path, default=None,
                    help="path to a file installed at /root/.ssh/authorized_keys")
    args = ap.parse_args()

    out = args.output
    out.mkdir(parents=True, exist_ok=True)
    repo = out / "repo"
    gens = out / "generations" / "1"
    sandbox = out / "_sandbox"
    repo.mkdir(parents=True, exist_ok=True)
    gens.mkdir(parents=True, exist_ok=True)

    pkg_list = [p.strip() for p in args.packages.split(",") if p.strip()]
    pkg_list = list(dict.fromkeys(SYSTEM_BASELINE + pkg_list))

    print(f"\n[bootstrap] mmdebstrap → {sandbox}", file=sys.stderr)
    mmdebstrap_sandbox(args.suite, args.mirror, pkg_list, sandbox)

    customize_sandbox(
        sandbox,
        hostname=args.hostname,
        ssh_host_keys_dir=args.ssh_host_keys,
        ssh_authorized_keys=args.ssh_authorized_keys,
    )

    pkgs = installed_packages(sandbox)
    print(f"\n[bootstrap] {len(pkgs)} packages installed in sandbox",
          file=sys.stderr)

    # Build a per-package staging area + pancake image for each.
    layer_records = []
    owned_paths: set[str] = set()
    with tempfile.TemporaryDirectory(prefix="pancake-stage-") as tmp:
        tmp = Path(tmp)
        for name, version, arch in pkgs:
            print(f"\n[bootstrap] {name} {version}", file=sys.stderr)
            files = package_files(sandbox, name)
            owned_paths.update(files)
            staging = tmp / name
            stage_files(sandbox, files, staging)

            slug = slugify_version(version)
            pkg_dir = repo / f"{name}-{slug}"
            if pkg_dir.exists():
                run(["rm", "-rf", str(pkg_dir)], sudo=True)
            pkg_dir.mkdir(parents=True)

            roothash, data_size = make_verity_image(
                staging, pkg_dir / "image.img", label=f"pk-{name[:12]}",
            )
            depends_field = package_field(sandbox, name, "Depends")
            # Description is multi-line; keep only the synopsis to keep the
            # manifest TOML well-formed (no embedded newlines / quotes).
            description = package_field(sandbox, name, "Description").splitlines()[0]
            description = description.replace('"', "'")
            write_manifest(
                pkg_dir,
                name=name, version=version, arch=arch,
                description=description,
                depends=parse_depends(depends_field),
                roothash=roothash, data_size=data_size,
            )
            layer_records.append({
                "name": name, "version": version, "arch": arch,
                "dir": pkg_dir.name,
            })

        # Catch-all: files in sandbox not owned by any package.
        # These are postinst side effects (e.g. /etc/passwd updates,
        # /etc/systemd/system/multi-user.target.wants/* symlinks).
        print("\n[bootstrap] computing orphan (postinst-created) files",
              file=sys.stderr)
        every = all_real_files(sandbox)
        # all_real_files returns paths starting with /. owned_paths comes
        # from dpkg-query -L which also returns leading /. Both relative-to-/.
        orphans = sorted(every - owned_paths)
        # Filter out runtime/cache state but KEEP /var/lib/dpkg so the booted
        # system (and `pancake add` later) can query "what's installed".
        ignore_patterns = (
            "/var/cache/", "/var/log/", "/var/lib/apt/",
            "/var/lib/systemd/random-seed",
            "/run/", "/proc/", "/sys/", "/dev/", "/tmp/",
        )
        orphans = [o for o in orphans
                   if not any(o.startswith(p) for p in ignore_patterns)]
        print(f"  → {len(orphans)} orphan files (kept)", file=sys.stderr)

        if orphans:
            staging = tmp / "_pancake-state"
            stage_files(sandbox, orphans, staging)
            pkg_dir = repo / "pancake-state"
            if pkg_dir.exists():
                run(["rm", "-rf", str(pkg_dir)], sudo=True)
            pkg_dir.mkdir(parents=True)
            roothash, data_size = make_verity_image(
                staging, pkg_dir / "image.img", label="pancake-state",
            )
            write_manifest(
                pkg_dir,
                name="pancake-state", version="1.0.0", arch="all",
                description="post-install state (users, unit symlinks, ...)",
                depends=[], roothash=roothash, data_size=data_size,
            )
            layer_records.append({
                "name": "pancake-state", "version": "1.0.0", "arch": "all",
                "dir": "pancake-state",
            })

    # Topological sort: dependencies first, then leaves last. We REVERSE for
    # overlay order so leaves (most-specific) end up leftmost = topmost.
    by_name = {L["name"]: L for L in layer_records}
    dep_first = topological_order(pkgs, sandbox)
    overlay_order: list[dict] = []
    # pancake-state always at the very top so its post-install bits win.
    if "pancake-state" in by_name:
        overlay_order.append(by_name["pancake-state"])
    for n in reversed(dep_first):
        if n in by_name:
            overlay_order.append(by_name[n])

    write_generation_manifest(
        gens, overlay_order, parent_id=None,
        description=f"initial generation ({len(overlay_order)} layers)",
        repo_dir=repo,
    )
    # current → generations/1
    current = out / "current"
    if current.is_symlink() or current.exists():
        current.unlink()
    current.symlink_to("generations/1")

    if not args.keep_sandbox:
        run(["rm", "-rf", str(sandbox)], sudo=True)

    print(f"\n[bootstrap] kit ready at {out}", file=sys.stderr)
    print(f"  layers: {len(overlay_order)}", file=sys.stderr)
    print(f"  generation: {gens}/manifest.toml", file=sys.stderr)
    print(f"  current → generations/1", file=sys.stderr)
    return 0


if __name__ == "__main__":
    sys.exit(main())
