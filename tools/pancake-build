#!/usr/bin/env python3
"""
pancake-build — turn a single .deb into a pancake image + manifest.

Process:

  1. Mount overlay sandbox: lower = the cumulative chroot of already-built
     packages, upper = scratch tmpfs.
  2. Bind /proc /sys /dev inside the sandbox (postinst usually wants them).
  3. Run `dpkg --install <pkg>.deb` inside the sandbox. dpkg unpacks AND
     configures, which fires preinst/postinst/triggers.
  4. The overlay's upper layer is exactly this package's contribution:
     files it shipped, plus anything postinst added (/etc/passwd entries,
     systemd unit symlinks, conffile fixups, ...).
  5. mkfs.ext4 + veritysetup format on the upper layer → image.img + image.hash
  6. Write manifest.toml with package metadata + roothash + Depends:.

Usage:
  pancake-build --deb foo.deb --lower CHROOT --repo OUTDIR
"""
from __future__ import annotations

import argparse
import os
import shutil
import sys
import tempfile
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parent))
from pancake_lib import (
    deb_metadata, file_sha256, make_verity_image, parse_depends, run,
    slugify_version, write_manifest,
)


def overlay_install(deb: Path, lower: Path, upper: Path, work: Path,
                    merged: Path) -> None:
    """Mount overlay(lower, upper, work) at merged and dpkg-install the .deb."""
    merged.mkdir(parents=True, exist_ok=True)
    upper.mkdir(parents=True, exist_ok=True)
    work.mkdir(parents=True, exist_ok=True)

    run(["mount", "-t", "overlay", "overlay",
         "-o", f"lowerdir={lower},upperdir={upper},workdir={work}",
         str(merged)], sudo=True)
    try:
        for sub in ("proc", "sys", "dev"):
            (merged / sub).mkdir(exist_ok=True)
            run(["mount", "--rbind", f"/{sub}", str(merged / sub)], sudo=True)

        in_chroot = merged / "tmp" / deb.name
        in_chroot.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(deb, in_chroot)

        env = {
            "DEBIAN_FRONTEND": "noninteractive",
            "DPKG_FORCE": "confnew",
            "PATH": "/usr/sbin:/usr/bin:/sbin:/bin",
            "LANG": "C.UTF-8",
        }
        # --force-depends: pancake-os manages deps via the generation manifest,
        # not via dpkg's status DB. We trust the caller to have ensured all
        # needed dep layers are stacked already.
        run(["chroot", str(merged), "dpkg", "--install",
             "--force-confnew", "--force-depends", "--no-triggers",
             f"/tmp/{deb.name}"],
            sudo=True, env={**os.environ, **env})
        run(["chroot", str(merged), "dpkg", "--triggers-only", "--pending"],
            sudo=True, env={**os.environ, **env}, check=False)

        run(["rm", "-f", str(in_chroot)], sudo=True)
    finally:
        for sub in ("dev", "sys", "proc"):
            run(["umount", "-l", str(merged / sub)], sudo=True, check=False)
        run(["umount", str(merged)], sudo=True, check=False)


def build_one(deb: Path, lower: Path, repo: Path) -> Path:
    md = deb_metadata(deb)
    pkg, ver = md["Package"], md["Version"]
    print(f"[pancake-build] {pkg} {ver}", file=sys.stderr)

    out_dir = repo / f"{pkg}-{slugify_version(ver)}"
    if out_dir.exists():
        run(["rm", "-rf", str(out_dir)], sudo=True)
    out_dir.mkdir(parents=True)

    with tempfile.TemporaryDirectory(prefix="pancake-build-") as tmp:
        tmp = Path(tmp)
        upper, work, merged = tmp / "upper", tmp / "work", tmp / "merged"
        overlay_install(deb, lower, upper, work, merged)
        roothash, data_size = make_verity_image(
            upper, out_dir / "image.img", label=f"pk-{pkg[:12]}",
        )

    write_manifest(
        out_dir,
        name=pkg, version=ver, arch=md.get("Architecture", "amd64"),
        description=md.get("Description", ""),
        depends=parse_depends(md.get("Depends", "")),
        deb_name=deb.name, deb_sha256=file_sha256(deb),
        roothash=roothash, data_size=data_size,
    )
    print(f"  → {out_dir}/image.img  roothash={roothash[:16]}…", file=sys.stderr)
    return out_dir


def main() -> int:
    ap = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    ap.add_argument("--deb", required=True, type=Path)
    ap.add_argument("--lower", required=True, type=Path,
                    help="dependency chroot to use as overlay lowerdir")
    ap.add_argument("--repo", required=True, type=Path,
                    help="output dir; package goes to <repo>/<name>-<ver>/")
    args = ap.parse_args()

    if not args.deb.is_file():
        print(f"no such .deb: {args.deb}", file=sys.stderr); return 2
    if not args.lower.is_dir():
        print(f"lower not a directory: {args.lower}", file=sys.stderr); return 2

    build_one(args.deb, args.lower, args.repo)
    return 0


if __name__ == "__main__":
    sys.exit(main())
