#!/bin/bash
# /init for pancake initramfs (unified-rootfs architecture).
#
# Requires kernel with Christian Brauner's "move_mount: allow MOVE_MOUNT_BENEATH
# on the rootfs" fix (in bpf-next/for-next, will land in 7.2).
#
# 1. mount procfs/sysfs/devtmpfs
# 2. modprobe dm-verity, overlay
# 3. parse pancake.pkg=NAME:DATA_SERIAL:HASH_SERIAL:ROOTHASH from /proc/cmdline
# 4. veritysetup open + RO mount each pkg's verity device under /lowers/$name
# 5. mount -t overlay  /sysroot   lowerdir=daemons:base, upperdir=tmpfs
# 6. move proc/sys/dev + lowers + tmpfs into /sysroot
# 7. switch_root to /sbin/init (systemd)
#
# After switch_root, / IS the merged overlay. A live swap then targets / via
# move_mount(... MOVE_MOUNT_BENEATH) which only works on the rootfs with the
# above kernel fix.

set -e
exec >/dev/console 2>&1
echo
echo "=== pancake-init starting ==="

mkdir -p /proc /sys /dev /run /lowers /sysroot /upper-tmp
mount -t proc     proc     /proc
mount -t sysfs    sys      /sys
mount -t devtmpfs dev      /dev

echo "[init] modprobe dm-mod dm-verity overlay"
/sbin/modprobe dm-mod    2>/dev/null || true
/sbin/modprobe dm-verity 2>/dev/null || /sbin/modprobe dm_verity
/sbin/modprobe overlay
/sbin/modprobe ext4      2>/dev/null || true

# Resolve a virtio-blk serial → /dev/vdX via sysfs (no udev in initramfs).
find_by_serial() {
    local want="$1" blk got
    for blk in /sys/block/vd*; do
        [ -f "$blk/serial" ] || continue
        got=$(cat "$blk/serial" 2>/dev/null || echo)
        if [ "$got" = "$want" ]; then
            echo "/dev/$(basename "$blk")"
            return 0
        fi
    done
    return 1
}

for _ in 1 2 3 4 5; do
    [ -n "$(ls /sys/block/vd* 2>/dev/null)" ] && break
    sleep 0.2
done

echo "[init] parsing /proc/cmdline"
PKGS=""
for arg in $(cat /proc/cmdline); do
    case "$arg" in
        pancake.pkg=*) PKGS="$PKGS ${arg#pancake.pkg=}" ;;
    esac
done
[ -n "$PKGS" ] || { echo "[init] FATAL: no pancake.pkg= on cmdline"; exec /bin/sh; }

# Open all verity devices and mount each at /lowers/$name (RO).
NAMES=""
for spec in $PKGS; do
    name=$(echo "$spec" | cut -d: -f1)
    data_serial=$(echo "$spec" | cut -d: -f2)
    hash_serial=$(echo "$spec" | cut -d: -f3)
    rh=$(echo "$spec"          | cut -d: -f4)

    data=$(find_by_serial "$data_serial") || { echo "[init] FATAL: no serial=$data_serial"; exec /bin/sh; }
    hash=$(find_by_serial "$hash_serial") || { echo "[init] FATAL: no serial=$hash_serial"; exec /bin/sh; }

    echo "[init] verity open $name (data=$data hash=$hash)"
    veritysetup open "$data" "v_$name" "$hash" "$rh"
    mkdir -p "/lowers/$name"
    mount -o ro "/dev/mapper/v_$name" "/lowers/$name"
    NAMES="$NAMES $name"
done

# Build the merged-rootfs overlay. Order: leftmost wins. Daemons first (so
# /etc/ssh comes from sshd image, /etc/chrony from chronyd image), then base.
mount -t tmpfs -o mode=755 tmpfs /upper-tmp
mkdir -p /upper-tmp/upper /upper-tmp/work

LOWERLIST=""
for name in $NAMES; do
    [ "$name" = "base" ] && continue
    [ -n "$LOWERLIST" ] && LOWERLIST="$LOWERLIST:"
    LOWERLIST="$LOWERLIST/lowers/$name"
done
[ -n "$LOWERLIST" ] && LOWERLIST="$LOWERLIST:/lowers/base" || LOWERLIST="/lowers/base"

echo "[init] mount -t overlay (lowerdir=$LOWERLIST)"
mount -t overlay -o "lowerdir=$LOWERLIST,upperdir=/upper-tmp/upper,workdir=/upper-tmp/work" \
    overlay /sysroot

# Make /sysroot's parent (initramfs tmpfs) propagation-private — keeps
# downstream mount manipulations sane.
mount --make-private /sysroot

# Move proc/sys/dev under /sysroot so they survive switch_root.
mkdir -p /sysroot/proc /sysroot/sys /sysroot/dev /sysroot/lowers /sysroot/run/pancake-rw
mount --move /proc /sysroot/proc
mount --move /sys  /sysroot/sys
mount --move /dev  /sysroot/dev

# Surface lowers under /sysroot/lowers/$name so swap-pkg.sh can address them.
for name in $NAMES; do
    mkdir -p "/sysroot/lowers/$name"
    mount --move "/lowers/$name" "/sysroot/lowers/$name"
done

# Move the upper-tmp tmpfs under /sysroot too.
mount --move /upper-tmp /sysroot/run/pancake-rw

echo "[init] switch_root → /sbin/init"
exec switch_root /sysroot /sbin/init
