# Docker build-context exclusions. Mirrors .gcloudignore.

# Big build artifacts at repo root (leading / anchors to root)
/pancake-state.img
/pancake-state.img.fresh
/pancake-efi.img
/pancake-initramfs.cpio.gz
/pancake-bzImage
/pancake
/pancaked
/pancake-build-server

# Operator runtime dirs (root-anchored)
/bin/
/pancake-host-state/
/pancake-kit/
/vm-state/

# VM image staging (huge, root-owned, regenerable)
vm/

# SvelteKit build artifacts (Dockerfile rebuilds them)
frontend/node_modules/
frontend/build/
frontend/.svelte-kit/

# Terraform local state + provider cache
deployment/terraform/.terraform/
deployment/terraform/terraform.tfstate*
deployment/terraform/*.tfplan

# Git pack files
.git/
.github/
