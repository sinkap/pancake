#!/bin/sh
# /etc/grub.d/12_sev_snp — emit a "SEV-SNP" boot variant for every
# installed Linux kernel. Drop in alongside 10_linux; runs on every
# `update-grub` (i.e. on every kernel install/upgrade), so the SNP
# entries stay in sync without manual intervention.
#
# What it does: for each /boot/vmlinuz-*, emits one extra menuentry
# named "Ubuntu (SEV-SNP), with Linux <ver>" whose cmdline is the
# system default plus:
#
#   kvm_amd.sev=1 kvm_amd.sev_es=1 kvm_amd.sev_snp=1
#
# Selecting that entry at boot brings the host up with the AMD KVM
# SNP module enabled. Default Ubuntu entries (from 10_linux) are
# untouched, so the regular boot still works.
#
# Install:
#   sudo install -m 0755 12_sev_snp /etc/grub.d/12_sev_snp
#   sudo update-grub
#
# Uninstall:
#   sudo rm /etc/grub.d/12_sev_snp && sudo update-grub

set -e
prefix=/usr
exec_prefix=${prefix}
datarootdir=${prefix}/share

# Source the system grub defaults so we inherit GRUB_CMDLINE_LINUX*
# (lockdown, vfio, amd_iommu=on, …). Everything stays the same; we
# just append the SNP enables.
if [ -r /etc/default/grub ]; then
    . /etc/default/grub
fi
GRUB_CMDLINE_LINUX_DEFAULT="${GRUB_CMDLINE_LINUX_DEFAULT:-}"
GRUB_CMDLINE_LINUX="${GRUB_CMDLINE_LINUX:-}"

SNP_CMDLINE="kvm_amd.sev=1 kvm_amd.sev_es=1 kvm_amd.sev_snp=1"

# Resolve root device + UUID from the running mount table. Mirrors
# what 10_linux's machinery does on a typical ext4 root. (For BTRFS
# subvols, LVM, encrypted, etc. the script would need extra logic;
# patches welcome.)
ROOT_UUID="$(findmnt / -no UUID 2>/dev/null || true)"
ROOT_FSTYPE="$(findmnt / -no FSTYPE 2>/dev/null || echo ext4)"
if [ -z "$ROOT_UUID" ]; then
    echo "12_sev_snp: could not resolve / UUID; skipping" >&2
    exit 0
fi

# Pick a stable submenu heading id so subsequent updates land in
# the same submenu (preserves user's "boot last selected" UX).
SUBMENU_ID="sev-snp-${ROOT_UUID}"

cat <<EOF
submenu 'SEV-SNP boot variants' \$menuentry_id_option '${SUBMENU_ID}' {
EOF

# Sort kernels newest-first so the latest version is the default
# selection inside the submenu. Same ordering 10_linux uses.
list=""
for f in /boot/vmlinuz-*; do
    case "$f" in
        *.dpkg-tmp|*.signed) continue ;;
    esac
    [ -e "$f" ] || continue
    list="$list $(basename "$f" | sed 's/^vmlinuz-//')"
done
sorted=$(echo "$list" | tr ' ' '\n' | sort -V -r | tr '\n' ' ')

for ver in $sorted; do
    [ -n "$ver" ] || continue
    initrd="/boot/initrd.img-$ver"
    [ -e "$initrd" ] || { echo "12_sev_snp: $initrd missing, skipping $ver" >&2; continue; }

    cat <<EOF
    menuentry 'Ubuntu (SEV-SNP), with Linux ${ver}' --class ubuntu --class gnu-linux --class gnu --class os \$menuentry_id_option 'sev-snp-${ver}-${ROOT_UUID}' {
        recordfail
        load_video
        gfxmode \$linux_gfx_mode
        insmod gzio
        insmod part_gpt
        insmod ${ROOT_FSTYPE}
        search --no-floppy --fs-uuid --set=root ${ROOT_UUID}
        echo    'Loading Linux ${ver} (SEV-SNP) ...'
        linux   /boot/vmlinuz-${ver} root=UUID=${ROOT_UUID} ro ${GRUB_CMDLINE_LINUX_DEFAULT} ${GRUB_CMDLINE_LINUX} ${SNP_CMDLINE}
        echo    'Loading initial ramdisk ...'
        initrd  ${initrd}
    }
EOF
done

cat <<EOF
}
EOF
