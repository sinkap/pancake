# gcloud / Cloud Build upload exclusions.
# Keep the source tree the three Dockerfiles need; drop image artifacts,
# chroot staging, VM state, the linux-bpf-for-next worktree, etc.

# Big build artifacts at repo root (leading / anchors to root —
# unanchored 'pancake' would also exclude cli/pancake/ and
# backends/pancaked/, breaking the Docker build).
/pancake-state.img
/pancake-state.img.fresh
/pancake-efi.img
/pancake-initramfs.cpio.gz
/pancake-bzImage
/pancake
/pancaked
/pancake-build-server

# Operator runtime dirs (root-anchored)
/bin/
/pancake-host-state/
/pancake-kit/
/vm-state/

# VM image staging (huge, root-owned, regenerable)
vm/

# SvelteKit build artifacts (Dockerfile rebuilds them)
frontend/node_modules/
frontend/build/
frontend/.svelte-kit/

# Terraform local state + provider cache
deployment/terraform/.terraform/
deployment/terraform/terraform.tfstate*
deployment/terraform/*.tfplan

# Local generated keys
*.tpm
*.key
*.tpmstate

# Git pack files are big
.git/
.github/

# Everything else: keep
